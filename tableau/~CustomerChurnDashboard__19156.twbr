      <aliases enabled='yes' />
      <column caption='Avg Charge Per Month' datatype='real' name='[AvgChargePerMonth]' role='dimension' type='quantitative' />
      <column caption='Churn Flag' datatype='integer' name='[Calculation_1316438216826880]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Churn] = 1 THEN 1 ELSE 0 END' />
      </column>
      <column caption='Churn Rate' datatype='real' default-format='p0.0%' name='[Calculation_1316438217461761]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Calculation_1316438216826880])' />
      </column>
      <column caption='Risk Bucket for Retention' datatype='string' name='[Calculation_1316438306799620]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [churn_probability] &lt; 0.3 THEN &quot;Low Risk&quot;&#13;&#10;ELSEIF [churn_probability] &lt; 0.6 THEN &quot;Medium Risk&quot;&#13;&#10;ELSE &quot;High Risk&quot;&#13;&#10;END' />
      </column>
      <column caption='Churn Probability (bin) ' datatype='integer' name='[Churn Probability (bin) 2]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='-1' formula='[churn_probability]' peg='0' size='0.1' />
      </column>
      <column aggregation='None' datatype='integer' name='[Churn Probability (bin)]' role='dimension' type='quantitative'>
        <calculation class='bin' decimals='-2' formula='[churn_probability]' peg='0' size='0.018' />
      </column>
      <column caption='Device Protection' datatype='string' name='[DeviceProtection]' role='dimension' type='nominal' />
